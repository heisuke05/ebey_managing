# ===== Google スプレッドシート連携(必須) =====
# 管理用スプレッドシートのID(URLの /d/ と /edit の間の文字列)
SHEET_ID=1xRs8ZkfiPFwZM9PGIAlaXKTqpwvAL9tUBh0xGlbBMEE
# Google Cloudのサービスアカウント(README参照)
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxxx@xxxx.iam.gserviceaccount.com
# サービスアカウントJSONの private_key をそのまま貼り付け(改行は \n のままでOK)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===== ログイン(必須) =====
# 家族共通の「あいことば」。好きな文字列に変更してください
FAMILY_PASSCODE=kazoku2026

# ===== プッシュ通知(必須) =====
# `npx web-push generate-vapid-keys` で生成した鍵ペア
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:takayamak44@worlddivinelight.org

# ===== 写真アップロード(Vercel上では自動設定) =====
# Vercelダッシュボード → Storage → Blob を作成すると自動で入ります
BLOB_READ_WRITE_TOKEN=

# ===== AI機能(任意) =====
# 商品検索の「AIに聞く」(約20円/回)と、AI市場提案(約100円/回)で使用。
# どちらもボタンを押した時だけ動作し、自動実行はしません。
ANTHROPIC_API_KEY=

# ===== 商品検索: eBay相場(任意) =====
# eBay開発者登録(無料)で発行される Production の App ID / Cert ID
# https://developer.ebay.com/ → Application Keys → Production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
